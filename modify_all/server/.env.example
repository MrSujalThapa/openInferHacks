# Server env — copy to modify_all/server/.env (preferred when using npm run dev:server)
# Or use modify_all/.env at the repo root if your shell cwd is the monorepo root.
# Blank OpenInfer vars enable deterministic mock mode for local demo.

PORT=4000
MONGODB_URI=mongodb://localhost:27017/genie_mvp
MONGODB_DB=genie_mvp
OPENINFER_BASE_URL=
OPENINFER_API_KEY=
OPENINFER_MODEL=
